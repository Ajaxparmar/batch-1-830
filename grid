<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        .container{
            display: grid;
            grid-template-columns: repeat(4, 1fr)

        }
        .box1{
            background-color: bisque;
            padding: 30px;
            margin: 10px;
        }
        .header{
        grid-column-start: 1;
        grid-column-end: 5;
        background-color: rgb(255, 255, 255);
        color: white;
        font-size: 32px;
        }
        .Hero{
            grid-column-start: 1;
            grid-column-end: 5;
            height: 600px; 
            background: url('banner.jpg');
            background-size: cover;
    
        }
        .menu{
            grid-row-start: 3;
            grid-row-end: 7;
            background-color: rgb(103, 22, 22);
            
        }
        .main{
            grid-column-start: 2;
            grid-column-end: 5;
            grid-row-start: 3;
            grid-row-end: 5;
        }
        .Banner{
            grid-column-start: 2;
            grid-column-end: 5;
        }
        .extra{
            grid-column-start: 2;
            grid-column-end: 4;  
        }
        .navbar{
            width: 90%;
            background-color: black;
            margin: 0px auto;
            border-radius: 50px;
            padding: 0px 20px;
        }
        .flex{
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo i{
            font-size: 48px;
        }
        .fire-me button{
            padding: 12px 24px;
            font-size: 32px;
            border: none;
            border-radius: 50px;
        }
        .nav-items ul li{
            list-style: none;
            padding: 12px 18px;
        }
        .nav-items ul li a{
            text-decoration: none;
            color: white;
        }

    </style>
</head>
<body>
    <div class="container">
        <div class="box1 header">
            <div class="navbar flex">
                <div class="logo">
                    <i class="fa-solid fa-fire"></i>
                </div>
                <div class="nav-items">
                    <ul class="flex">
                        <li><a href="">Home</a></li>
                        <li><a href="">Work</a></li>
                        <li><a href="">price</a></li>
                        <li><a href="">Project</a></li>
                        <li><a href="">Contact</a></li>
                    </ul>
                </div>
                <div class="fire-me">
                    <button>fire@gmail.com</button>
                </div>
            </div>
        </div>
        <div class="box1 Hero">Hero</div>
        <div class="box1 menu">Menu</div>
        <div class="box1 main">Main</div>
        <div class="box1 Banner">Banner</div>
        <div class="box1 extra">extra</div>
        <div class="box1">Image</div>

    </div>
    
</body>
</html>
